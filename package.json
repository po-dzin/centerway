{
  "name": "centerway-platform",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 8000",
    "build": "next build --webpack",
    "start": "next start -p 8000",
    "lint": "eslint src next.config.ts eslint.config.mjs",
    "tokens:build": "node scripts/generate-design-tokens.mjs",
    "canon:guard": "node scripts/guard-platform-canon.mjs",
    "guard:ds-contract": "node scripts/guard-ds-contract.mjs",
    "semantic:audit": "node scripts/semantic-audit.mjs",
    "generator:validate": "node scripts/generator-validate.mjs",
    "guard:rhythm": "node scripts/guard-rhythm-grid.mjs",
    "generator:snapshot": "node scripts/generator-build-snapshots.mjs",
    "generator:determinism": "node scripts/generator-determinism.mjs",
    "generator:language": "node scripts/generator-language-guard.mjs",
    "generator:gate": "npm run generator:validate && npm run generator:snapshot && npm run generator:determinism && npm run generator:language && npm run guard:rhythm",
    "smoke:admin": "node scripts/smoke-admin-api.mjs",
    "smoke:admin:auth": "node scripts/smoke-admin-api.mjs --require-auth",
    "smoke:admin:authz-surface": "node scripts/smoke-admin-authz-surface.mjs",
    "smoke:admin:funnel": "node scripts/smoke-admin-funnel-consistency.mjs",
    "smoke:admin:landing-offers": "node scripts/smoke-admin-landing-offers.mjs",
    "smoke:admin:payload-contracts": "node scripts/smoke-admin-payload-contracts.mjs",
    "smoke:admin:write-guards": "node scripts/smoke-admin-write-guards.mjs",
    "smoke:admin:authz-coverage": "node scripts/smoke-admin-authz-coverage.mjs",
    "smoke:admin:governance": "node scripts/smoke-admin-governance.mjs",
    "smoke:admin:i18n-tone": "node scripts/smoke-admin-i18n-tone.mjs",
    "smoke:admin:a11y-contract": "node scripts/smoke-admin-a11y-contract.mjs",
    "smoke:admin:responsive": "node scripts/smoke-admin-responsive.mjs",
    "smoke:admin:ci": "node scripts/smoke-admin-ci.mjs",
    "smoke:admin:ui": "node scripts/smoke-admin-ui.mjs",
    "smoke:landing:dynamic-offer": "node scripts/smoke-landing-dynamic-offer.mjs",
    "smoke:dosha:result": "node scripts/smoke-dosha-result-engine.mjs",
    "smoke:dosha:api": "node scripts/smoke-dosha-api-flow.mjs",
    "smoke:dosha:userflows": "node scripts/smoke-dosha-userflows.mjs",
    "smoke:dosha:responsive": "node scripts/smoke-dosha-responsive.mjs",
    "smoke:dosha:brand-fit": "node scripts/smoke-dosha-brand-fit.mjs",
    "smoke:landing:short-irem": "node scripts/smoke-landing-short-irem.mjs",
    "smoke:landing:next-contract": "node scripts/smoke-landing-next-contract.mjs",
    "smoke:landing:cutover-toggle": "node scripts/smoke-landing-cutover-toggle.mjs",
    "gate:landing:short-irem": "node scripts/landing-gate-short-irem.mjs",
    "baseline:landing:short-irem": "node scripts/baseline-landing-short-irem.mjs",
    "tg:webhook:set": "node scripts/set-telegram-webhook.mjs",
    "smoke:landing:qa": "npm run smoke:landing:short-irem",
    "ds:qa": "npm run canon:guard && npm run tokens:build && npm run guard:ds-contract && npm run generator:validate && npm run semantic:audit && npm run lint && npm run build",
    "ds:qa:landing": "npm run guard:ds-contract && npm run smoke:landing:qa",
    "smoke:dosha:route": "npm run smoke:dosha:userflows && npm run smoke:dosha:brand-fit",
    "smoke:dosha:qa": "npm run smoke:dosha:result && npm run smoke:dosha:api && npm run smoke:dosha:userflows && npm run smoke:dosha:responsive && npm run smoke:dosha:brand-fit"
  },
  "dependencies": {
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.93.1",
    "@vercel/analytics": "^2.0.1",
    "next": "16.1.5",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.27",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.5",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "typescript": "^5"
  }
